# CMAPSS API Configuration

# Port to run the server on (default: 8000)
PORT=8000

# Host to bind the server to (default: 0.0.0.0)
HOST=0.0.0.0

# Comma-separated list of allowed origins for CORS (default: *)
ALLOWED_ORIGINS=*

# Enable debug/reload mode (default: false)
DEBUG=false

# Feature Flags
# (Add any other environment variables here)
